<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-23" version="21.0.0">
  <diagram name="Data Flow Diagram" id="dfd-diagram">
    <mxGraphModel dx="2200" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="Multi-Agent Business Intelligence — Data Flow Diagram" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="20" width="1200" height="50" as="geometry" />
        </mxCell>

        <!-- =========================================================== -->
        <!--  COLUMN 1 — USER  (x ~ 80)                                  -->
        <!-- =========================================================== -->
        <mxCell id="user" value="User" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=#ffffff;fontColor=#ffffff;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- =========================================================== -->
        <!--  COLUMN 2 — CLIENT  (x ~ 300)                               -->
        <!-- =========================================================== -->
        <mxCell id="client" value="client.py&#xa;region: us-west-2&#xa;read_timeout: 900s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="130" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- =========================================================== -->
        <!--  COLUMN 3 — REQUEST / GATEWAY  (x ~ 570)                    -->
        <!-- =========================================================== -->
        <mxCell id="d-payload" value="{mode, company | message,&#xa;session_id}" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="135" width="230" height="55" as="geometry" />
        </mxCell>

        <mxCell id="handle" value="handle_request()&#xa;sanitize · regex · max 200 chars" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7157B;strokeColor=#C0006A;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="260" width="230" height="65" as="geometry" />
        </mxCell>

        <mxCell id="ds-rate" value="Rate Limiter&#xa;5 req/min per client" style="shape=mxgraph.dfd.dataStore;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="380" width="200" height="55" as="geometry" />
        </mxCell>

        <!-- =========================================================== -->
        <!--  COLUMN 4 — ORCHESTRATORS / CORE AGENTS  (x ~ 920)          -->
        <!-- =========================================================== -->

        <!-- Research Orchestrator -->
        <mxCell id="research-phase" value="Analyst Orchestrator&#xa;Claude Sonnet 4 (temp=0.3)&#xa;tools: financial_analyst,&#xa;competitive_analyst" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;strokeColor=#001DBC;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="200" width="260" height="90" as="geometry" />
        </mxCell>

        <!-- TAI Report -->
        <mxCell id="d-tai" value="TAI Report" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="940" y="480" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Innovation Agent -->
        <mxCell id="innovation" value="Innovation Agent&#xa;Claude Sonnet 4 (temp=0.7)&#xa;No tools · no new research" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="600" width="260" height="75" as="geometry" />
        </mxCell>

        <!-- Opportunity Report -->
        <mxCell id="d-opp" value="Opportunity Report" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="940" y="750" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Chat Agent -->
        <mxCell id="chat-agent" value="Chat Agent&#xa;Claude Sonnet 4 (temp=0.3)&#xa;SlidingWindow (size=40)&#xa;TAI + Opp in system prompt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="960" width="260" height="85" as="geometry" />
        </mxCell>

        <!-- =========================================================== -->
        <!--  COLUMN 5 — SUB-AGENTS / TOOLS  (x ~ 1320)                  -->
        <!-- =========================================================== -->

        <!-- Financial Analyst -->
        <mxCell id="fin-agent" value="financial_analyst()&#xa;Claude 3 Haiku (temp=0.2)&#xa;tools: web_search" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007bff;strokeColor=#0056b3;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1320" y="160" width="230" height="70" as="geometry" />
        </mxCell>

        <!-- Competitive Analyst -->
        <mxCell id="comp-agent" value="competitive_analyst()&#xa;Claude 3 Haiku (temp=0.2)&#xa;tools: web_search" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007bff;strokeColor=#0056b3;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1320" y="290" width="230" height="70" as="geometry" />
        </mxCell>

        <!-- web_search tool -->
        <mxCell id="websearch" value="web_search()&#xa;requests lib · HTTPS only&#xa;timeout: 10s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=#6B37CC;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1680" y="210" width="210" height="70" as="geometry" />
        </mxCell>

        <!-- Session Store -->
        <mxCell id="ds-session" value="SessionStore (In-Memory LRU)&#xa;keys: tai_report, opportunity_report, chat_agent&#xa;TTL: 3600s · Max: 100 sessions" style="shape=mxgraph.dfd.dataStore;whiteSpace=wrap;html=1;fillColor=#FF8000;strokeColor=#CC6600;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1320" y="740" width="290" height="70" as="geometry" />
        </mxCell>

        <!-- Analyze Response -->
        <mxCell id="d-analyze-resp" value="{tai_report, opportunity_report,&#xa;session_id}" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1320" y="870" width="260" height="55" as="geometry" />
        </mxCell>

        <!-- Chat input -->
        <mxCell id="d-chat-in" value="{mode: chat, message,&#xa;session_id}" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="975" width="230" height="55" as="geometry" />
        </mxCell>

        <!-- Chat output -->
        <mxCell id="d-chat-out" value="{response, session_id}" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="1080" width="210" height="50" as="geometry" />
        </mxCell>

        <!-- =========================================================== -->
        <!--  COLUMN 6 — EXTERNAL / AWS SERVICES  (x ~ 2040)             -->
        <!-- =========================================================== -->

        <!-- DuckDuckGo -->
        <mxCell id="ddg" value="DuckDuckGo API&#xa;api.duckduckgo.com" style="ellipse;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=#6B37CC;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="2040" y="200" width="210" height="80" as="geometry" />
        </mxCell>

        <!-- Amazon Bedrock -->
        <mxCell id="bedrock" value="Amazon Bedrock&#xa;Model Inference API&#xa;(Sonnet 4 + Haiku 3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#01A88D;strokeColor=#007A65;fontColor=#ffffff;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="2040" y="460" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Amazon CloudWatch -->
        <mxCell id="cloudwatch" value="Amazon CloudWatch&#xa;Audit Logs +&#xa;OpenTelemetry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7157B;strokeColor=#C0006A;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="2040" y="700" width="220" height="75" as="geometry" />
        </mxCell>

        <!-- =========================================================== -->
        <!--  EDGES — ENTRY FLOW  (left to right)                         -->
        <!-- =========================================================== -->
        <mxCell id="e-user-client" value="input" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="user" target="client" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-client-payload" value="invoke_agent_runtime()" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="client" target="d-payload" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-payload-handle" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="d-payload" target="handle" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-handle-rate" value="check limit" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;dashed=1;" edge="1" source="handle" target="ds-rate" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- =========================================================== -->
        <!--  EDGES — RESEARCH PHASE (Phase 1)                            -->
        <!-- =========================================================== -->
        <mxCell id="e-handle-research" value="company (sanitized)&#xa;session_id = secrets.token_hex(16)" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="handle" target="research-phase" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-research-fin" value="company" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="research-phase" target="fin-agent" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-research-comp" value="company" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="research-phase" target="comp-agent" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-fin-search" value="search query" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="fin-agent" target="websearch" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-comp-search" value="search query" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="comp-agent" target="websearch" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-search-ddg" value="HTTPS GET → JSON (max 50KB)" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="websearch" target="ddg" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-research-tai" value="synthesized report" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="research-phase" target="d-tai" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- =========================================================== -->
        <!--  EDGES — INNOVATION PHASE (Phase 2)                          -->
        <!-- =========================================================== -->
        <mxCell id="e-tai-innov" value="TAI Report" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="d-tai" target="innovation" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-innov-opp" value="10-15 opportunities" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="innovation" target="d-opp" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-opp-session" value="store in session" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="d-opp" target="ds-session" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-session-resp" value="return analyze response" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="ds-session" target="d-analyze-resp" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-resp-client" value="response to client" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="d-analyze-resp" target="client" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1450" y="950"/><mxPoint x="380" y="950"/></Array></mxGeometry>
        </mxCell>

        <!-- =========================================================== -->
        <!--  EDGES — CHAT PHASE (Phase 3)                                -->
        <!-- =========================================================== -->
        <mxCell id="e-handle-chat" value="chat request" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="handle" target="d-chat-in" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="675" y="340"/><mxPoint x="675" y="340"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="e-chatin-agent" value="message" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="d-chat-in" target="chat-agent" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-session-chat" value="_sessions.get(session_id)" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;dashed=1;" edge="1" source="ds-session" target="chat-agent" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1465" y="1000"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="e-chat-out" value="response" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="chat-agent" target="d-chat-out" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="880" y="1105"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="e-chatout-user" value="to user" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="d-chat-out" target="user" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="140" y="1105"/></Array></mxGeometry>
        </mxCell>

        <!-- =========================================================== -->
        <!--  EDGES — BEDROCK (grouped)                                   -->
        <!-- =========================================================== -->
        <!-- Research agents → Bedrock -->
        <mxCell id="e-research-bedrock" value="All research agents&#xa;(Sonnet 4 + Haiku 3)" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;dashed=1;strokeColor=#01A88D;" edge="1" source="research-phase" target="bedrock" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1050" y="400"/><mxPoint x="1050" y="500"/><mxPoint x="2150" y="500"/></Array></mxGeometry>
        </mxCell>
        <!-- Innovation + Chat → Bedrock -->
        <mxCell id="e-innov-bedrock" value="Claude Sonnet 4" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;dashed=1;strokeColor=#01A88D;" edge="1" source="innovation" target="bedrock" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1250" y="637"/><mxPoint x="1250" y="500"/><mxPoint x="2040" y="500"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="e-chat-bedrock" value="Claude Sonnet 4" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;dashed=1;strokeColor=#01A88D;" edge="1" source="chat-agent" target="bedrock" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1250" y="1002"/><mxPoint x="1250" y="540"/><mxPoint x="2040" y="540"/></Array></mxGeometry>
        </mxCell>

        <!-- =========================================================== -->
        <!--  EDGES — CLOUDWATCH (audit + telemetry)                      -->
        <!-- =========================================================== -->
        <mxCell id="e-handle-cw" value="REQUEST / RATE_LIMITED&#xa;ANALYZE / ANALYZE_COMPLETE&#xa;INVALID_INPUT / UNKNOWN_MODE" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;dashed=1;" edge="1" source="handle" target="cloudwatch" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="790" y="310"/><mxPoint x="810" y="310"/><mxPoint x="810" y="737"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="e-websearch-cw" value="SEARCH_FAILED" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;dashed=1;" edge="1" source="websearch" target="cloudwatch" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1785" y="300"/><mxPoint x="1960" y="300"/><mxPoint x="1960" y="737"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="e-session-cw" value="SESSION_EVICTED&#xa;(lru | ttl)" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;dashed=1;" edge="1" source="ds-session" target="cloudwatch" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- OTel traces -->
        <mxCell id="e-otel-cw" value="OTel traces" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;dashed=1;strokeColor=#E7157B;" edge="1" source="client" target="cloudwatch" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="380" y="90"/><mxPoint x="2150" y="90"/><mxPoint x="2150" y="700"/></Array></mxGeometry>
        </mxCell>

        <!-- =========================================================== -->
        <!--  ANNOTATION — Chat validation                                -->
        <!-- =========================================================== -->
        <mxCell id="note-chat-checks" value="1. if not message → error&#xa;2. validate session_id" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#fffacd;strokeColor=#999;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="1060" width="170" height="40" as="geometry" />
        </mxCell>
        <mxCell id="e-note-chat" style="edgeStyle=orthogonalEdgeStyle;dashed=1;fontSize=10;" edge="1" source="d-chat-in" target="note-chat-checks" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- =========================================================== -->
        <!--  LEGEND                                                      -->
        <!-- =========================================================== -->
        <mxCell id="legend" value="Legend" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="2040" y="900" width="260" height="280" as="geometry" />
        </mxCell>
        <mxCell id="l-proc" value="Process / Agent" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="15" y="40" width="130" height="30" as="geometry" />
        </mxCell>
        <mxCell id="l-data" value="Data Flow" style="shape=parallelogram;perimeter=parallelogramPerimeter;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="15" y="80" width="130" height="30" as="geometry" />
        </mxCell>
        <mxCell id="l-store" value="Data Store" style="shape=mxgraph.dfd.dataStore;fillColor=#FF8000;strokeColor=#CC6600;fontColor=#ffffff;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="15" y="120" width="130" height="30" as="geometry" />
        </mxCell>
        <mxCell id="l-ext" value="External Entity" style="ellipse;fillColor=#232F3E;strokeColor=#ffffff;fontColor=#ffffff;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="15" y="160" width="130" height="30" as="geometry" />
        </mxCell>
        <mxCell id="l-aws" value="AWS Service" style="rounded=1;fillColor=#01A88D;strokeColor=#007A65;fontColor=#ffffff;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="15" y="200" width="130" height="30" as="geometry" />
        </mxCell>
        <mxCell id="l-sync" value="— Sync call" style="text;html=1;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="155" y="40" width="95" height="30" as="geometry" />
        </mxCell>
        <mxCell id="l-async" value="- - Async / internal" style="text;html=1;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="155" y="80" width="95" height="30" as="geometry" />
        </mxCell>
        <mxCell id="l-note" value="Annotation" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#fffacd;strokeColor=#999;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="155" y="120" width="95" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
